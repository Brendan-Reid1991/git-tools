#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMON_LIB="${SCRIPT_DIR}/../lib/git-tools-common.sh"
if [[ ! -f "${COMMON_LIB}" ]]; then
  COMMON_LIB="${SCRIPT_DIR}/lib/git-tools-common.sh"
fi
if [[ ! -f "${COMMON_LIB}" ]]; then
  printf 'Error: unable to locate git-tools-common.sh\n' >&2
  exit 1
fi
source "${COMMON_LIB}"

usage() {
  cat <<'EOF'
Usage: git superadd [files...] -m "commit message"

Examples:
  git superadd file1.txt file2.txt -m "chore: update files"
  git superadd -m "feat: commit everything staged + unstaged"
EOF
}

require_git_repo

MESSAGE=""
FILES=()

while (($#)); do
  case "$1" in
    -m|--message)
      shift
      if (($# == 0)); then
        die "missing commit message after -m/--message."
      fi
      MESSAGE="$1"
      ;;
    --)
      shift
      while (($#)); do
        FILES+=("$1")
        shift
      done
      break
      ;;
    -*)
      usage >&2
      die "unknown option: $1"
      ;;
    *)
      FILES+=("$1")
      ;;
  esac
  shift
done

if [[ -z "$MESSAGE" ]]; then
  usage >&2
  die "commit message is required."
fi

if ((${#FILES[@]} > 0)); then
  git add "${FILES[@]}"
else
  git add -A
fi

for attempt in {1..5}; do
  if git commit -m "$MESSAGE"; then
    exit 0
  fi
  printf 'Commit failed, retrying (%d/5)...\n' "$attempt" >&2
done

die "commit failed after 5 attempts."
